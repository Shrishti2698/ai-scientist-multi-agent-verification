\def\addcolour#1#2#3#4{		% \addcolour{name}{red}{green}{blue}
  \special{ps:(#1) #2 #3 #4 addclr}
}

\def\colouring#1{%		% \colouring{name}
  \special{ps:(#1) clr}%
}

\let\@colouring=\colouring

\def\colourpush{%		% \colourpush
  \special{ps: clrpush}%	% push current red/green/blue
}

\let\@colourpush=\colourpush

\def\colour#1{%			% \begin{colour}{name}
  \colourpush%
  \colouring{#1}%
}

\def\endcolour{%		% \end{colour}
  \special{ps: clrpop}%		% pop previous red/green/blue
}

\let\colourpop=\endcolour	% no parameters

\let\@colourpop=\colourpop

\def\nocolours{			% no parameters
  \def\colouring##1{}
  \def\colour##1{}
  \def\endcolour{}
  \def\framecolours##1##2{}
}
