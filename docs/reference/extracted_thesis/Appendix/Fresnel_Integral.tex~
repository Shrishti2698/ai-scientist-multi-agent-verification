%\textbf{Fresnel Integral:}
{\LARGE F}resnel integrals are transcendental functions named after Augustin-Jean Fresnel that are used in diffraction phenomena, and are defined through the following integral representations \cite{Boersma_fri_i}\index{Fresnel integral}:
%{\LARGE T}he Fresnel Integral \cite{Boersma_fri_i} define in the form of
\begin{eqnarray}\label{fresnel_appendix_1}
f\left(X\right)=\int_0^X \frac{e^{-\imath t}}{\sqrt{2\pi t}}\mathrm{dt}
\end{eqnarray}
Two approximations, one valid for $X$ less than $4$ and the other valid for $X$ larger than $4$ for the Fresnel integration are the following:
\begin{subequations}\label{fresnel_appendix_2}
\begin{enumerate}
\item For $0\leq X\leq 4$
\begin{eqnarray}\label{fresnel_appendix_2a}
f\left(X\right)=e^{-\imath X}\sqrt{\frac{X}{4}}\sum_{n=0}^{11}\left(a_n+\imath b_n\right)\left(\frac{X}{4}\right)^n
\end{eqnarray}
\item For $X\geq 4$
\begin{eqnarray}\label{fresnel_appendix_2b}
f\left(X\right)=\frac{1-\imath}{2}+e^{-\imath X}\sqrt{\frac{4}{X}}\sum_{n=0}^{11}\left(c_n+\imath d_n\right)\left(\frac{4}{X}\right)^n
\end{eqnarray}
\end{enumerate}
\end{subequations}
