The modified Fresnel integral $F\left(X\right)$ in \cite{Pathak_utd} is
\be\label{fresnel__appendix_3} 
F\left(X\right)=2j\sqrt{X}\exp{\left(jX\right)}\int^\infty_{\sqrt{X}}\exp{\left(-j\tau^2\right)d\tau} 
\ee 
Taking $\tau^2=t$
\be\label{fresnel_appendix_3} 
F\left(X\right)&=&j\sqrt{X}\exp{\left(jX\right)}\int^\infty_X\frac{\exp{\left(-jt\right)}}{\sqrt{t}}dt\nonumber\\ 
&=&j\sqrt{2\pi X}\exp{\left(jX\right)}\int^\infty_X\frac{\exp{\left(-jt\right)}}{\sqrt{2\pi t}}dt\nonumber\\ 
&=&j\sqrt{2\pi X}\exp{\left(jX\right)}\left[\int^\infty_0\frac{\exp{\left(-jt\right)}}{\sqrt{2\pi t}}dt-\int^X_0\frac{\exp{\left(-jt\right)}}{\sqrt{2\pi t}}dt\right]\nonumber\\ 
&=&j\sqrt{2\pi X}\exp{\left(jX\right)}\left[\left(\frac{1-j}{2}\right)-\int^X_0\frac{\exp{\left(-jt\right)}}{\sqrt{2\pi t}}dt\right]
\ee  
From the Eqns.~(\ref{fresnel_appendix_1}) \& (\ref{fresnel__appendix_3})
\be\label{fresnel_appendix_5} 
F\left(X\right)=j\sqrt{2\pi X}\exp{\left(jX\right)}\left[\left(\frac{1-j}{2}\right)-f(X)\right]
\ee  
The modified Fresnel integral $F_s\left(X\right)$ in slope diffraction coefficient \cite{Balanis_book}, \cite{Y_T_Lo_edited_book} is
\be\label{slfres_appendix_1} 
F_s\left(X\right)=2jX\left[1-j2\sqrt{X}e^{jX}\int^\infty_{\sqrt{X}}\exp{\left(-j\tau^2\right)d\tau}\right]=2jX\left[1-F\left(X\right)\right]
\ee



