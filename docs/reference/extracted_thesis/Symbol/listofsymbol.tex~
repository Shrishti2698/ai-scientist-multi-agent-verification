\begin{large}
\textbf{Operators and symbolic notations}
\end{large}



\begin{flushleft}
\begin{longtable}{lp{9.3cm}}
$A_x\arrowvert ^n_{i,j,k}$ & :x component of vector $\overrightarrow{A}$ at location $i\Delta _x,~j\Delta _y,~k\Delta _z$ evaluated at time $n\Delta t$\\
$R_e \{z\}$ &:the real part of the complex number z\\
$\sum_{i=1}^n a_i$ &:sum of the n terms $a_1$,......., $a_n$\\
$\overrightarrow{A} \cdot \overrightarrow{B}$ &:dot product of vectors $\overrightarrow{A}$  and $\overrightarrow{B}$\\
$\overrightarrow{A} \times \overrightarrow{B}$ &:cross product of vectors $\overrightarrow{A}$ and $\overrightarrow{B}$\\
$\frac{d}{dt}$ &:derivative with respect to t\\
$\frac{\partial}{\partial t},~D_t$ &:partial derivative with respect to t\\
$\bigtriangledown \cdot \overrightarrow{A}$ &:divergence of vector $\overrightarrow{A}$ in continuum space\\
$\bigtriangledown \times \overrightarrow{A}$ &:curl of vector $\overrightarrow{A}$ in continuum space\\
%$\bigtriangledown \odot \overrightarrow{A}$ &:divergence of vector $\overrightarrow{A}$ in discrete space\\
%$\bigtriangledown \otimes \overrightarrow{A}$ &:curl of vector $\overrightarrow{A}$ in discrete space\\
$\frac{d^2}{dt^2} $ &:second derivative with respect to t\\
$\bigtriangledown ^2 $ &:Laplace operator\\
\end{longtable}
\end{flushleft}



















