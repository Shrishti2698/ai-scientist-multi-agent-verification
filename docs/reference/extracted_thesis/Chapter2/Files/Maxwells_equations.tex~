In rectangular coordinates, (\ref{Faraday_eqn2}) and (\ref{Ampere_eqn2}) can be written as
\begin{subequations}\label{Faraday_eqn3}
\begin{eqnarray}
\mu\frac{\partial H_x}{\partial t}=\frac{\partial E_y}{\partial z}-\frac{\partial E_z}{\partial y}\label{FE_3a}\\
\mu\frac{\partial H_y}{\partial t}=\frac{\partial E_z}{\partial x}-\frac{\partial E_x}{\partial z}\label{FE_3b}\\
\mu\frac{\partial H_z}{\partial t}=\frac{\partial E_x}{\partial y}-\frac{\partial E_y}{\partial x}\label{FE_3c}
\end{eqnarray}
\end{subequations}
\begin{subequations}\label{Ampere_eqn3}
\begin{eqnarray}
\epsilon\frac{\partial E_x}{\partial t}=\frac{\partial H_z}{\partial y}-\frac{\partial H_y}{\partial z}\label{AE_3a}\\
\epsilon\frac{\partial E_y}{\partial t}=\frac{\partial H_x}{\partial z}-\frac{\partial H_z}{\partial x}\label{AE_3b}\\
\epsilon\frac{\partial E_z}{\partial t}=\frac{\partial H_y}{\partial x}-\frac{\partial H_x}{\partial y}\label{AE_3c}
\end{eqnarray}
\end{subequations}













