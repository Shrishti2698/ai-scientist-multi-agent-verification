A difference approximation of the space and time derivatives is needed in order to discretize the differential form of Maxwell\rq s equations. The Taylor series expansion of a certain variable at the current space location and time step is given by
\begin{eqnarray}\label{Taylor_series_expansion}
\frac{\partial f(x_0)}{\partial x}=\frac{f(x_0+\bigtriangleup x)-f(x_0-\bigtriangleup x)}{2\bigtriangleup x}+0[(\bigtriangleup x)^2]
\end{eqnarray}
Here, the first part of the Taylor series expansion or the central difference approximation is chosen because it is computationally simple and has relatively good second-order accuracy. So the discretized Maxwell\rq s equations can be derived from (\ref{Faraday_eqn3}) to (\ref{Ampere_eqn3}) using the notation of (\ref{Taylor_series_expansion}) and difference approximations. For single electromagnetic components in Maxwell\rq s equations, for example $H_x$, the averaging of the two consecutive time step\rq s value is applied in discretized equations.
%\begin{small}
\begin{subequations}\label{E_3d}
\begin{align}
&E_x^{n+1}(i+1/2,j,k)=E_x^{n+0}(i+1/2,j,k)\label{Ex_3d}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup y \varepsilon_0\varepsilon_r(i+1/2,j,k)}}\right)\left[H_z^{n+1/2}(i+1/2,j+1/2,k)-H_z^{n+1/2}(i+1/2,j-1/2,k)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup z \varepsilon_0\varepsilon_r(i+1/2,j,k)}}\right)\left[H_y^{n+1/2}(i+1/2,j,k+1/2)-H_y^{n+1/2}(i+1/2,j,k-1/2)\right]\\
&E_y^{n+1}(i,j+1/2,k)=E_y^{n+0}(i,j+1/2,k)\label{Ey_3d}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup z \varepsilon_0\varepsilon_r(i,j+1/2,k)}}\right)\left[H_x^{n+1/2}(i,j+1/2,k+1/2)-H_x^{n+1/2}(i,j+1/2,k-1/2)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup x \varepsilon_0\varepsilon_r(i,j+1/2,k)}}\right)\left[H_z^{n+1/2}(i+1/2,j+1/2,k)-H_y^{n+1/2}(i-1/2,j+1/2,k)\right]\\
&E_z^{n+1}(i,j,k+1/2)=E_z^{n+0}(i,j,k+1/2)\label{Ez_3d}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup x \varepsilon_0\varepsilon_r(i,j,k+1/2)}}\right)\left[H_y^{n+1/2}(i+1/2,j,k+1/2)-H_y^{n+1/2}(i-1/2,j,k+1/2)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup y \varepsilon_0\varepsilon_r(i,j,k+1/2)}}\right)\left[H_x^{n+1/2}(i,j+1/2,k+1/2)-H_x^{n+1/2}(i,j-1/2,k+1/2)\right]
\end{align}
\end{subequations}
\begin{subequations}\label{H_3d}
\begin{align}
&H_x^{n+1/2}(i,j+1/2,k+1/2)=H_x^{n-1/2}(i,j+1/2,k+1/2)\label{Hx_3d}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup z \mu_0\mu_r(i,j+1/2,k+1/2)}}\right)\left[E_y^{n}(i,j+1/2,k+1)-E_y^{n}(i,j+1/2,k)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup y \mu_0\mu_r(i,j+1/2,k+1/2)}}\right)\left[E_z^{n}(i,j+1,k+1/2)-E_z^{n}(i,j,k+1/2)\right]\\
&H_y^{n+1/2}(i+1/2,j+1/2,k)=H_y^{n-1/2}(i+1/2,j+1/2,k)\label{Hy_3d}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup x \mu_0\mu_r(i+1/2,j,k+1/2)}}\right)\left[E_z^{n}(i+1,j,k+1/2)-E_z^{n}(i,j,k+1/2)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup z \mu_0\mu_r(i+1/2,j,k+1/2)}}\right)\left[E_x^{n}(i+1/2,j,k+1)-E_x^{n}(i+1/2,j,k)\right]\\
&H_z^{n+1/2}(i+1/2,j+1/2,k)=H_z^{n-1/2}(i+1/2,j+1/2,k)\label{Hz_3d}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup y \mu_0\mu_r(i+1/2,j+1/2,k)}}\right)\left[E_x^{n}(i+1/2,j+1,k)-E_x^{n}(i+1/2,j,k)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup x \mu_0\mu_r(i+1/2,j+1/2,k)}}\right)\left[E_y^{n}(i+1,j+1/2,k)-E_y^{n}(i,j+1/2,k)\right]
\end{align}
\end{subequations}
%\end{small}
The Eqns.~(\ref{E_3d}) and (\ref{H_3d}) are very similar, but because $\varepsilon_0$ and $\mu_0$ differ by several orders of magnitude, $\overrightarrow E$ and $\overrightarrow H$ will differ by several orders of magnitude \cite{Taflove_Numerical_Solution_Steady_State_Electromagnetic_Scattering}, \cite{Sullivan_book_00}. This is circumvented by making the following change of variable: 
\begin{eqnarray}\label{E_nor}
\overrightarrow E=\sqrt{\frac{\varepsilon_0}{\mu_0}}\overrightarrow E
\end{eqnarray}
Substituting (\ref{E_nor}) into (\ref{E_3d}) and (\ref{H_3d}) gives
\begin{small}
\begin{subequations}\label{E_3d2}
\begin{align}
&E_x^{n+1}(i+1/2,j,k)=E_x^{n+0}(i+1/2,j,k)\label{Ex_3d2}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup y \sqrt{\varepsilon_0\mu_0}\varepsilon_r(i+1/2,j,k)}}\right)\left[H_z^{n+1/2}(i+1/2,j+1/2,k)-H_z^{n+1/2}(i+1/2,j-1/2,k)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup z \sqrt{\varepsilon_0\mu_0}\varepsilon_r(i+1/2,j,k)}}\right)\left[H_y^{n+1/2}(i+1/2,j,k+1/2)-H_y^{n+1/2}(i+1/2,j,k-1/2)\right]\\
&E_y^{n+1}(i,j+1/2,k)=E_y^{n+0}(i,j+1/2,k)\label{Ey_3d2}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup z \sqrt{\varepsilon_0\mu_0}\varepsilon_r(i,j+1/2,k)}}\right)\left[H_x^{n+1/2}(i,j+1/2,k+1/2)-H_x^{n+1/2}(i,j+1/2,k-1/2)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup x \sqrt{\varepsilon_0\mu_0}\varepsilon_r(i,j+1/2,k)}}\right)\left[H_z^{n+1/2}(i+1/2,j+1/2,k)-H_y^{n+1/2}(i-1/2,j+1/2,k)\right]\\
&E_z^{n+1}(i,j,k+1/2)=E_z^{n+0}(i,j,k+1/2)\label{Ez_3d2}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup x \sqrt{\varepsilon_0\mu_0}\varepsilon_r(i,j,k+1/2)}}\right)\left[H_y^{n+1/2}(i+1/2,j,k+1/2)-H_y^{n+1/2}(i-1/2,j,k+1/2)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup y \sqrt{\varepsilon_0\mu_0}\varepsilon_r(i,j,k+1/2)}}\right)\left[H_x^{n+1/2}(i,j+1/2,k+1/2)-H_x^{n+1/2}(i,j-1/2,k+1/2)\right]
\end{align}
\end{subequations}
\begin{subequations}\label{H_3d2}
\begin{align}
&H_x^{n+1/2}(i,j+1/2,k+1/2)=H_x^{n-1/2}(i,j+1/2,k+1/2)\label{Hx_3d2}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup z \sqrt{\varepsilon_0\mu_0}\mu_r(i,j+1/2,k+1/2)}}\right)\left[E_y^{n}(i,j+1/2,k+1)-E_y^{n}(i,j+1/2,k)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup y \sqrt{\varepsilon_0\mu_0}\mu_r(i,j+1/2,k+1/2)}}\right)\left[E_z^{n}(i,j+1,k+1/2)-E_z^{n}(i,j,k+1/2)\right]\\
&H_y^{n+1/2}(i+1/2,j+1/2,k)=H_y^{n-1/2}(i+1/2,j+1/2,k)\label{Hy_3d2}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup x \sqrt{\varepsilon_0\mu_0}\mu_r(i+1/2,j,k+1/2)}}\right)\left[E_z^{n}(i+1,j,k+1/2)-E_z^{n}(i,j,k+1/2)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup z \sqrt{\varepsilon_0\mu_0}\mu_r(i+1/2,j,k+1/2)}}\right)\left[E_x^{n}(i+1/2,j,k+1)-E_x^{n}(i+1/2,j,k)\right]\\
&H_z^{n+1/2}(i+1/2,j+1/2,k)=H_z^{n-1/2}(i+1/2,j+1/2,k)\label{Hz_3d2}\nonumber\\
&\quad+\left({\frac{\bigtriangleup t}{\bigtriangleup y \sqrt{\varepsilon_0\mu_0}\mu_r(i+1/2,j+1/2,k)}}\right)\left[E_x^{n}(i+1/2,j+1,k)-E_x^{n}(i+1/2,j,k)\right]\nonumber\\
&\quad-\left({\frac{\bigtriangleup t}{\bigtriangleup x \sqrt{\varepsilon_0\mu_0}\mu_r(i+1/2,j+1/2,k)}}\right)\left[E_y^{n}(i+1,j+1/2,k)-E_y^{n}(i,j+1/2,k)\right]
\end{align}
\end{subequations}
\end{small}
This algorithm is accurate and flexible and its most appealing characteristic is its simplicity of computation and structure. All the operations in (\ref{Ex_3d2}) to (\ref{Hz_3d2}) are additions, subtractions and multiplications, which are easy to compute and cost relative few resources in a hardware implementation. The structures of these six equations are almost the same, making it possible to apply various methods to speed up the algorithm, such as custom hardware implementation and parallel computing. A complete FDTD model can be structured as shown in Fig.~\ref{Fig:structure_diagram_FDTD}. The algorithm simply iterates the same procedures for each time step in the time domain making the computation regular.
